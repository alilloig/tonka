#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$HOME/.tonka.conf"
BASE_VM_NAME="tonka-base"
VM_NAME="tonka-vm"
SSH_KEY="$HOME/.ssh/id_ed25519_tonka"
TART_USER="$(whoami)"

# Load config file if it exists
if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
fi

# Set defaults for configurable values (after config file is loaded)
TONKA_BASE_IMAGE="${TONKA_BASE_IMAGE:-ghcr.io/cirruslabs/macos-tahoe-xcode:latest}"
TONKA_DISK_SIZE="${TONKA_DISK_SIZE:-}"
TONKA_CPU="${TONKA_CPU:-$(sysctl -n hw.ncpu)}"
TONKA_MEMORY="${TONKA_MEMORY:-$(( $(sysctl -n hw.memsize) * 5 / 8 / 1024 / 1024 ))}"

# Get GitHub token from gh CLI if not set
if [[ -z "${GITHUB_TOKEN:-}" ]] && command -v gh &>/dev/null; then
    GITHUB_TOKEN="$(gh auth token 2>/dev/null || true)"
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}[tonka]${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}[tonka]${NC} $*"
}

log_error() {
    echo -e "${RED}[tonka]${NC} $*" >&2
}

die() {
    log_error "$@"
    exit 1
}

usage() {
    cat <<EOF
Usage: tonka <command> [arguments]

Commands:
  new-repo <repo-path>      Clone a git repo into the VM
  new <project> [repo]      Create a project worktree from a repo
  pr <pr#> [repo]           Checkout a PR (creates project or opens existing)
  cp <src> [dest]           Copy a local file/directory into the VM (dest defaults to ~)
  sync                      Fetch branches from VM repo to current local repo
  sh [project]              SSH into VM (optionally into a project)
  cl <project>              Run Claude in a project
  cursor <project>          Open project in Cursor/VS Code via SSH
  diff <project>            Sync and diff project against origin/main
  difftool <project>        Sync and open difftool for project against origin/main
  start                     Start the tonka VM
  stop                      Stop the tonka VM
  list                      List repos and projects
  cleanup                   Remove merged worktrees
  rebuild-base              Rebuild the base VM from scratch
  doctor                    Diagnose sync state between host and VM

Examples:
  tonka new-repo ~/dev/myproject
  tonka new feature-branch myproject
  tonka pr 123
  tonka cp ~/myfile.txt ~/projects/myproject/
  tonka sh feature-branch
  tonka cl feature-branch
  tonka cursor feature-branch
EOF
}

ensure_ssh_key() {
    if [[ ! -f "$SSH_KEY" ]]; then
        log_info "Generating SSH key pair for tonka..."
        ssh-keygen -t ed25519 -f "$SSH_KEY" -N "" -C "tonka"
    fi
}

update_ssh_config() {
    local ip="$1"
    local ssh_config="$HOME/.ssh/config"
    local host_block="Host tonka
    HostName $ip
    User $TART_USER
    IdentityFile $SSH_KEY
    StrictHostKeyChecking no"

    # Ensure .ssh directory exists
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"

    if [[ ! -f "$ssh_config" ]]; then
        # No config file exists, offer to create it
        read -p "Create ~/.ssh/config with tonka host? [Y/n] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Nn]$ ]]; then
            echo "$host_block" > "$ssh_config"
            chmod 600 "$ssh_config"
            log_info "Created ~/.ssh/config with tonka host"
        fi
        return
    fi

    if ! grep -q "^Host tonka$" "$ssh_config" 2>/dev/null; then
        # Config exists but no tonka host, offer to add it
        read -p "Add tonka host to ~/.ssh/config? [Y/n] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Nn]$ ]]; then
            echo -e "\n$host_block" >> "$ssh_config"
            log_info "Added tonka host to ~/.ssh/config"
        fi
        return
    fi

    # Host exists, update IP if changed
    local current_ip
    current_ip=$(grep -A1 "^Host tonka$" "$ssh_config" | grep HostName | awk '{print $2}')
    if [[ "$current_ip" != "$ip" ]]; then
        # Update the HostName for tonka host
        sed -i '' '/^Host tonka$/,/^Host /{s/^[[:space:]]*HostName .*/    HostName '"$ip"'/;}' "$ssh_config"
        log_info "Updated tonka IP in ~/.ssh/config"
    fi
}

get_vm_ip() {
    local vm_name="$1"
    tart ip "$vm_name" 2>/dev/null || echo ""
}

wait_for_vm_ip() {
    local vm_name="$1"
    local max_attempts=60
    local attempt=0
    local ip=""

    while [[ -z "$ip" && $attempt -lt $max_attempts ]]; do
        ip=$(get_vm_ip "$vm_name")
        if [[ -z "$ip" ]]; then
            sleep 1
            ((attempt++))
        fi
    done

    if [[ -z "$ip" ]]; then
        die "Failed to get IP for VM $vm_name after $max_attempts seconds"
    fi
    echo "$ip"
}

wait_for_ssh() {
    local ip="$1"
    local max_attempts=60
    local attempt=0

    while ! ssh -o ConnectTimeout=2 -o StrictHostKeyChecking=no -o BatchMode=yes -i "$SSH_KEY" "$TART_USER@$ip" true 2>/dev/null; do
        sleep 1
        ((attempt++))
        if [[ $attempt -ge $max_attempts ]]; then
            die "SSH not ready after $max_attempts seconds"
        fi
    done
}

vm_exists() {
    local vm_name="$1"
    tart list | awk '{print $2}' | grep -q "^$vm_name$"
}

vm_is_running() {
    local vm_name="$1"
    tart list | grep "[[:space:]]$vm_name[[:space:]]" | grep -q "running"
}

base_vm_exists() {
    vm_exists "$BASE_VM_NAME"
}

ensure_base_vm() {
    if ! base_vm_exists; then
        log_info "Base VM not found. Creating it now..."
        create_base_vm
    fi
}

ensure_vm() {
    ensure_base_vm
    if ! vm_exists "$VM_NAME"; then
        log_info "Creating tonka VM from base..."
        tart clone "$BASE_VM_NAME" "$VM_NAME"
        log_info "Configuring VM: ${TONKA_CPU} CPUs, ${TONKA_MEMORY}MB RAM..."
        tart set "$VM_NAME" --cpu "$TONKA_CPU" --memory "$TONKA_MEMORY"
        if [[ -n "$TONKA_DISK_SIZE" ]]; then
            log_info "Setting disk size to ${TONKA_DISK_SIZE}GB..."
            tart set "$VM_NAME" --disk-size "$TONKA_DISK_SIZE"
        fi
    fi
    if ! vm_is_running "$VM_NAME"; then
        log_info "Starting tonka VM..."
        tart run --no-graphics "$VM_NAME" &
        disown $! 2>/dev/null || true
        sleep 15
        local ip
        ip=$(wait_for_vm_ip "$VM_NAME")
        wait_for_ssh "$ip"
        update_ssh_config "$ip"
        log_info "VM ready at $ip"
    else
        # VM already running, still update SSH config in case IP changed
        local ip
        ip=$(get_vm_ip "$VM_NAME")
        update_ssh_config "$ip"
    fi
}

sync_file() {
    local src="$1"
    local dest="$2"
    local ip="$3"
    local ssh_opts="$4"
    local local_hash remote_hash
    local_hash=$(md5 -q "$src")
    remote_hash=$(ssh $ssh_opts "$TART_USER@$ip" "md5 -q $dest 2>/dev/null" || echo "")
    if [[ "$local_hash" != "$remote_hash" ]]; then
        if scp $ssh_opts "$src" "$TART_USER@$ip:$dest"; then
            changed=true
        else
            log_warn "Failed to sync $(basename "$src")"
            ((sync_errors++)) || true
        fi
    fi
}

sync_dir() {
    local src="$1"
    local dest_parent="$2"
    local ip="$3"
    local ssh_opts="$4"
    local dir_name local_hash remote_hash
    dir_name=$(basename "$src")
    local_hash=$(find -H "$src" -type f -not -name '.DS_Store' -exec md5 -q {} \; | sort | md5 -q)
    remote_hash=$(ssh $ssh_opts "$TART_USER@$ip" "find ${dest_parent}/${dir_name} -type f -not -name '.DS_Store' -exec md5 -q {} \; 2>/dev/null | sort | md5 -q" || echo "")
    if [[ "$local_hash" != "$remote_hash" ]]; then
        if scp -r $ssh_opts "$src" "$TART_USER@$ip:$dest_parent/"; then
            changed=true
        else
            log_warn "Failed to sync $dir_name/"
            ((sync_errors++)) || true
        fi
    fi
}

sync_claude_settings() {
    local ip
    ip=$(get_vm_ip "$VM_NAME")
    local ssh_opts="-o StrictHostKeyChecking=no -i $SSH_KEY"
    local changed=false
    local sync_errors=0

    ssh $ssh_opts "$TART_USER@$ip" "mkdir -p ~/.claude ~/.config/gh"

    # Sync settings.json
    if [[ -f "$HOME/.claude/settings.json" ]]; then
        sync_file "$HOME/.claude/settings.json" "~/.claude/settings.json" "$ip" "$ssh_opts"
    fi

    # Sync CLAUDE.md (global instructions)
    if [[ -f "$HOME/.claude/CLAUDE.md" ]]; then
        sync_file "$HOME/.claude/CLAUDE.md" "~/.claude/CLAUDE.md" "$ip" "$ssh_opts"
    fi

    # Sync settings.local.json (permissions allowlist)
    if [[ -f "$HOME/.claude/settings.local.json" ]]; then
        sync_file "$HOME/.claude/settings.local.json" "~/.claude/settings.local.json" "$ip" "$ssh_opts"
    fi

    # Sync skills/
    if [[ -d "$HOME/.claude/skills" ]]; then
        sync_dir "$HOME/.claude/skills" "~/.claude" "$ip" "$ssh_opts"
    fi

    # Sync commands/
    if [[ -d "$HOME/.claude/commands" ]]; then
        sync_dir "$HOME/.claude/commands" "~/.claude" "$ip" "$ssh_opts"
    fi

    # Sync hooks/
    if [[ -d "$HOME/.claude/hooks" ]]; then
        sync_dir "$HOME/.claude/hooks" "~/.claude" "$ip" "$ssh_opts"
        ssh $ssh_opts "$TART_USER@$ip" "find ~/.claude/hooks -name '*.sh' -exec chmod +x {} \;" 2>/dev/null || true
    fi

    # Sync gh auth credentials
    if [[ -f "$HOME/.config/gh/hosts.yml" ]]; then
        sync_file "$HOME/.config/gh/hosts.yml" "~/.config/gh/hosts.yml" "$ip" "$ssh_opts"
    fi

    # Ensure git uses gh credential helper (clear xcode's osxkeychain first)
    if ! ssh $ssh_opts "$TART_USER@$ip" "git config --global --get credential.helper | grep -q 'gh auth'"; then
        log_info "Configuring git to use gh credential helper..."
        ssh $ssh_opts "$TART_USER@$ip" 'git config --global --unset-all credential.helper 2>/dev/null; git config --global credential.helper ""; git config --global --add credential.helper "/opt/homebrew/bin/gh auth git-credential"'
    fi

    # Install plugins if not already installed
    if [[ -f "$HOME/.claude/plugins/installed_plugins.json" ]]; then
        local plugins
        plugins=$(jq -r '.plugins | keys[]' "$HOME/.claude/plugins/installed_plugins.json" 2>/dev/null || echo "")

        # Ensure official marketplace is added
        if [[ -n "$plugins" ]]; then
            if ! ssh $ssh_opts "$TART_USER@$ip" "grep -q claude-plugins-official ~/.claude/plugins/known_marketplaces.json 2>/dev/null"; then
                log_info "Adding official plugin marketplace..."
                ssh $ssh_opts "$TART_USER@$ip" "~/.local/bin/claude plugin marketplace add anthropics/claude-plugins-official" || true
            fi
        fi

        for plugin in $plugins; do
            if ssh $ssh_opts "$TART_USER@$ip" "test -f ~/.claude/plugins/installed_plugins.json && grep -q '$plugin' ~/.claude/plugins/installed_plugins.json"; then
                continue
            fi
            log_info "Installing plugin: $plugin"
            ssh $ssh_opts "$TART_USER@$ip" "~/.local/bin/claude plugin install '$plugin'" || true
            changed=true
        done
    fi

    # Copy ~/.claude.json only if it doesn't exist (for initial onboarding state)
    if [[ -f "$HOME/.claude.json" ]]; then
        if ! ssh $ssh_opts "$TART_USER@$ip" "test -f ~/.claude.json" 2>/dev/null; then
            if scp $ssh_opts "$HOME/.claude.json" "$TART_USER@$ip:~/.claude.json"; then
                changed=true
            else
                log_warn "Failed to sync .claude.json"
                ((sync_errors++)) || true
            fi
        fi
    fi

    # Sync credentials from Keychain
    local creds
    creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || echo "")
    if [[ -n "$creds" ]]; then
        local local_hash remote_hash
        local_hash=$(echo "$creds" | md5 -q)
        remote_hash=$(ssh $ssh_opts "$TART_USER@$ip" "md5 -q ~/.claude/.credentials.json 2>/dev/null" || echo "")
        if [[ "$local_hash" != "$remote_hash" ]]; then
            if echo "$creds" | ssh $ssh_opts "$TART_USER@$ip" "cat > ~/.claude/.credentials.json"; then
                changed=true
            else
                log_warn "Failed to sync credentials"
                ((sync_errors++)) || true
            fi
        fi
    fi

    # Post-sync verification: check items present on host exist on VM
    local verify_cmds=""
    [[ -f "$HOME/.claude/settings.json" ]] && verify_cmds="${verify_cmds}[ -f ~/.claude/settings.json ] || printf ' settings.json';"
    [[ -f "$HOME/.claude/CLAUDE.md" ]] && verify_cmds="${verify_cmds}[ -f ~/.claude/CLAUDE.md ] || printf ' CLAUDE.md';"
    [[ -f "$HOME/.claude/settings.local.json" ]] && verify_cmds="${verify_cmds}[ -f ~/.claude/settings.local.json ] || printf ' settings.local.json';"
    [[ -d "$HOME/.claude/skills" ]] && verify_cmds="${verify_cmds}[ -d ~/.claude/skills ] || printf ' skills/';"
    [[ -d "$HOME/.claude/commands" ]] && verify_cmds="${verify_cmds}[ -d ~/.claude/commands ] || printf ' commands/';"
    [[ -d "$HOME/.claude/hooks" ]] && verify_cmds="${verify_cmds}[ -d ~/.claude/hooks ] || printf ' hooks/';"
    [[ -n "$creds" ]] && verify_cmds="${verify_cmds}[ -f ~/.claude/.credentials.json ] || printf ' .credentials.json';"

    if [[ -n "$verify_cmds" ]]; then
        local missing
        missing=$(ssh $ssh_opts "$TART_USER@$ip" "$verify_cmds" 2>/dev/null || echo "")
        if [[ -n "$missing" ]]; then
            log_warn "Missing in VM after sync:$missing"
        fi
    fi

    if [[ $sync_errors -gt 0 ]]; then
        log_warn "$sync_errors sync item(s) failed. Run 'tonka doctor' to diagnose."
    elif [[ "$changed" == "true" ]]; then
        log_info "Claude settings synced."
    fi
}

create_base_vm() {
    log_info "Creating base VM '$BASE_VM_NAME'..."

    # Check for sshpass (needed for initial password auth)
    if ! command -v sshpass &>/dev/null; then
        die "sshpass is required for base VM setup. Install with: brew install sshpass"
    fi

    ensure_ssh_key

    # Clone the base macOS image
    log_info "Cloning $TONKA_BASE_IMAGE..."
    tart clone "$TONKA_BASE_IMAGE" "$BASE_VM_NAME"
    log_info "Configuring VM: ${TONKA_CPU} CPUs, ${TONKA_MEMORY}MB RAM..."
    tart set "$BASE_VM_NAME" --cpu "$TONKA_CPU" --memory "$TONKA_MEMORY"
    if [[ -n "$TONKA_DISK_SIZE" ]]; then
        log_info "Setting disk size to ${TONKA_DISK_SIZE}GB..."
        tart set "$BASE_VM_NAME" --disk-size "$TONKA_DISK_SIZE"
    fi

    log_info "Starting base VM for configuration..."
    tart run --no-graphics "$BASE_VM_NAME" &
    local vm_pid=$!

    # Wait for VM to boot and get IP
    log_info "Waiting for VM to boot..."
    sleep 30  # Initial boot delay
    local ip
    ip=$(wait_for_vm_ip "$BASE_VM_NAME")
    log_info "VM IP: $ip"

    # Wait for SSH with default credentials (admin/admin)
    log_info "Waiting for SSH to be ready..."
    local max_attempts=60
    local attempt=0
    while ! sshpass -p admin ssh -o ConnectTimeout=2 -o StrictHostKeyChecking=no admin@"$ip" true 2>/dev/null; do
        sleep 1
        ((attempt++))
        if [[ $attempt -ge $max_attempts ]]; then
            kill $vm_pid 2>/dev/null || true
            die "SSH not ready after $max_attempts seconds"
        fi
    done

    # Get host brew packages
    log_info "Getting host brew packages..."
    local brew_formulae=""
    local brew_casks=""
    if command -v brew &>/dev/null; then
        brew_formulae=$(brew list --formula | tr '\n' ' ')
        brew_casks=$(brew list --cask | tr '\n' ' ')
    fi

    # Copy install script and SSH keys (using sshpass for password auth)
    log_info "Copying install script to VM..."
    sshpass -p admin scp -o StrictHostKeyChecking=no "$SCRIPT_DIR/guest/install.sh" admin@"$ip":/tmp/install.sh
    sshpass -p admin scp -o StrictHostKeyChecking=no "$SSH_KEY.pub" admin@"$ip":/tmp/tonka.pub
    sshpass -p admin scp -o StrictHostKeyChecking=no "$SSH_KEY" admin@"$ip":/tmp/tonka_key

    # Copy Claude settings if they exist
    if [[ -f "$HOME/.claude/settings.json" ]]; then
        log_info "Copying Claude settings..."
        sshpass -p admin scp -o StrictHostKeyChecking=no "$HOME/.claude/settings.json" admin@"$ip":/tmp/claude_settings.json
    fi
    if [[ -d "$HOME/.claude/skills" ]]; then
        log_info "Copying Claude skills..."
        sshpass -p admin scp -r -o StrictHostKeyChecking=no "$HOME/.claude/skills" admin@"$ip":/tmp/claude_skills
    fi
    if [[ -f "$HOME/.claude/CLAUDE.md" ]]; then
        log_info "Copying Claude global instructions..."
        sshpass -p admin scp -o StrictHostKeyChecking=no "$HOME/.claude/CLAUDE.md" admin@"$ip":/tmp/claude_claude_md
    fi
    if [[ -f "$HOME/.claude/settings.local.json" ]]; then
        log_info "Copying Claude local settings..."
        sshpass -p admin scp -o StrictHostKeyChecking=no "$HOME/.claude/settings.local.json" admin@"$ip":/tmp/claude_settings_local.json
    fi
    if [[ -d "$HOME/.claude/commands" ]]; then
        log_info "Copying Claude commands..."
        sshpass -p admin scp -r -o StrictHostKeyChecking=no "$HOME/.claude/commands" admin@"$ip":/tmp/claude_commands
    fi
    if [[ -d "$HOME/.claude/hooks" ]]; then
        log_info "Copying Claude hooks..."
        sshpass -p admin scp -r -o StrictHostKeyChecking=no "$HOME/.claude/hooks" admin@"$ip":/tmp/claude_hooks
    fi

    # Run install script with config
    log_info "Running install script on base VM..."
    local install_env="TONKA_USER='$TART_USER'"
    if [[ -n "${TONKA_DOTFILES_REPO:-}" ]]; then
        install_env="$install_env TONKA_DOTFILES_REPO='$TONKA_DOTFILES_REPO'"
    fi
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        install_env="$install_env GITHUB_TOKEN='$GITHUB_TOKEN'"
    fi
    if [[ -n "${TONKA_TOOLS:-}" ]]; then
        install_env="$install_env TONKA_TOOLS='$TONKA_TOOLS'"
    fi
    if [[ -n "$brew_formulae" ]]; then
        install_env="$install_env BREW_FORMULAE='$brew_formulae'"
    fi
    if [[ -n "$brew_casks" ]]; then
        install_env="$install_env BREW_CASKS='$brew_casks'"
    fi
    sshpass -p admin ssh -o StrictHostKeyChecking=no admin@"$ip" "chmod +x /tmp/install.sh && $install_env /tmp/install.sh"

    log_info "Stopping base VM..."
    tart stop "$BASE_VM_NAME"
    wait $vm_pid 2>/dev/null || true

    log_info "Base VM '$BASE_VM_NAME' created successfully!"
}

ssh_to_https() {
    local url="$1"
    # Convert git@github.com:user/repo.git to https://github.com/user/repo.git
    if [[ "$url" =~ ^git@([^:]+):(.+)$ ]]; then
        echo "https://${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
    else
        echo "$url"
    fi
}

cmd_new_repo() {
    local repo_path="${1:-}"
    if [[ -z "$repo_path" ]]; then
        die "Usage: tonka new-repo <repo-path>"
    fi
    repo_path="$(cd "$repo_path" && pwd)"
    if [[ ! -d "$repo_path/.git" ]]; then
        die "Not a git repository: $repo_path"
    fi
    local repo_name
    repo_name="$(basename "$repo_path")"
    local git_remote
    git_remote=$(git -C "$repo_path" remote get-url origin 2>/dev/null || echo "")
    if [[ -z "$git_remote" ]]; then
        die "No git remote 'origin' found"
    fi
    # Convert SSH URL to HTTPS for gh credential helper
    git_remote=$(ssh_to_https "$git_remote")

    ensure_vm
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    log_info "Cloning $repo_name into VM..."
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" \
        "mkdir -p ~/repos && git clone '$git_remote' ~/repos/$repo_name"
    log_info "Repo '$repo_name' added. Create a project with: tonka new <project-name> $repo_name"
}

cmd_new() {
    local project_name="${1:-}"
    local repo_name="${2:-}"
    if [[ -z "$project_name" ]]; then
        die "Usage: tonka new <project-name> [repo-name]"
    fi

    ensure_vm
    sync_claude_settings
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    # If no repo specified, try to find one
    if [[ -z "$repo_name" ]]; then
        repo_name=$(ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" "ls ~/repos 2>/dev/null | head -1" || echo "")
        if [[ -z "$repo_name" ]]; then
            die "No repos found. Add one with: tonka new-repo <repo-path>"
        fi
        log_info "Using repo: $repo_name"
    fi

    log_info "Creating worktree '$project_name' from '$repo_name'..."
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" \
        "mkdir -p ~/projects && cd ~/repos/$repo_name && git worktree add ~/projects/$project_name -b $project_name"

    log_info "Starting Claude in $project_name..."
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" -t "$TART_USER@$ip" \
        "cd ~/projects/$project_name && \$SHELL -i -l -c '~/.local/bin/claude --dangerously-skip-permissions; echo \"Claude exited. You are still in the tonka VM. Press Ctrl-D to leave.\"; exec \$SHELL -l'"
}

cmd_pr() {
    local pr_number="${1:-}"
    local repo_name="${2:-}"

    if [[ -z "$pr_number" ]]; then
        die "Usage: tonka pr <pr-number> [repo-name]"
    fi

    ensure_vm
    sync_claude_settings
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    # If no repo specified, try to find one
    if [[ -z "$repo_name" ]]; then
        repo_name=$(ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" "ls ~/repos 2>/dev/null | head -1" || echo "")
        if [[ -z "$repo_name" ]]; then
            die "No repos found. Add one with: tonka new-repo <repo-path>"
        fi
        log_info "Using repo: $repo_name"
    fi

    # Get the PR's branch name
    log_info "Looking up PR #$pr_number..."
    local branch_name
    branch_name=$(ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" \
        "cd ~/repos/$repo_name && /opt/homebrew/bin/gh pr view $pr_number --json headRefName -q .headRefName")

    if [[ -z "$branch_name" ]]; then
        die "Could not find PR #$pr_number"
    fi

    log_info "PR #$pr_number branch: $branch_name"

    # Check if any worktree has this branch checked out
    local worktree_path
    worktree_path=$(ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" \
        "cd ~/repos/$repo_name && git worktree list --porcelain | grep -B2 'branch refs/heads/$branch_name' | head -1 | sed 's/^worktree //'") || true

    if [[ -n "$worktree_path" ]]; then
        log_info "Found existing project at $worktree_path. Starting Claude..."
        ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" -t "$TART_USER@$ip" \
            "cd '$worktree_path' && \$SHELL -i -l -c '~/.local/bin/claude --dangerously-skip-permissions; echo \"Claude exited. You are still in the tonka VM. Press Ctrl-D to leave.\"; exec \$SHELL -l'"
        return
    fi

    # No existing project found, create one with the branch name
    log_info "Fetching PR #$pr_number..."
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" \
        "cd ~/repos/$repo_name && git fetch origin pull/$pr_number/head:$branch_name"

    log_info "Creating worktree '$branch_name'..."
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" \
        "mkdir -p ~/projects && cd ~/repos/$repo_name && git worktree add ~/projects/$branch_name $branch_name"

    log_info "Starting Claude in $branch_name..."
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" -t "$TART_USER@$ip" \
        "cd ~/projects/$branch_name && \$SHELL -i -l -c '~/.local/bin/claude --dangerously-skip-permissions; echo \"Claude exited. You are still in the tonka VM. Press Ctrl-D to leave.\"; exec \$SHELL -l'"
}

cmd_cp() {
    local src="${1:-}"
    local dest="${2:-}"

    if [[ -z "$src" ]]; then
        die "Usage: tonka cp <src> [dest]"
    fi

    if [[ ! -e "$src" ]]; then
        die "Source path does not exist: $src"
    fi

    ensure_vm
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    log_info "Copying $src to VM:${dest:-~}..."
    scp -r -o StrictHostKeyChecking=no -i "$SSH_KEY" "$src" "$TART_USER@$ip:$dest"
    log_info "Done."
}

cmd_sync() {
    local repo_root
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || die "Not in a git repository"
    local repo_name
    repo_name=$(basename "$repo_root")

    ensure_vm
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    # Check if the repo exists in the VM
    if ! ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" "test -d ~/repos/$repo_name" 2>/dev/null; then
        die "Repo '$repo_name' not found in VM. Add it with: tonka new-repo $repo_root"
    fi

    log_info "Fetching branches from VM repo '$repo_name'..."
    GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=no -i $SSH_KEY" \
        git -C "$repo_root" fetch "$TART_USER@$ip:repos/$repo_name" '+refs/heads/*:refs/remotes/tonka/*'
    log_info "Done. Branches available as tonka/<branch>"
}

cmd_start() {
    ensure_vm
}

cmd_stop() {
    if ! vm_is_running "$VM_NAME"; then
        log_warn "VM is not running"
        return
    fi
    log_info "Stopping tonka VM..."
    tart stop "$VM_NAME"
    log_info "VM stopped."
}

cmd_list() {
    if ! vm_is_running "$VM_NAME"; then
        log_warn "VM is not running. Start with: tonka start"
        return
    fi
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    log_info "Repos:"
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" "ls ~/repos 2>/dev/null" | while read -r r; do
        echo "  $r"
    done

    log_info "Projects:"
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" "ls ~/projects 2>/dev/null" | while read -r p; do
        echo "  $p"
    done
}

cmd_cleanup() {
    if ! vm_is_running "$VM_NAME"; then
        die "VM is not running. Start with: tonka start"
    fi
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    log_info "Cleaning up merged worktrees..."
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" '
        for repo in ~/repos/*; do
            [ -d "$repo" ] || continue
            cd "$repo"
            git worktree prune
        done
    '
    log_info "Done."
}

cmd_sh() {
    local project_name="${1:-}"
    ensure_vm
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    local cd_cmd=""
    if [[ -n "$project_name" ]]; then
        cd_cmd="cd ~/projects/$project_name && "
    fi

    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" -t "$TART_USER@$ip" "${cd_cmd}exec \$SHELL -l"
}

cmd_cl() {
    local project_name="${1:-}"
    if [[ -z "$project_name" ]]; then
        die "Usage: tonka cl <project>"
    fi
    ensure_vm
    sync_claude_settings
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    log_info "Starting Claude in $project_name..."
    ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" -t "$TART_USER@$ip" \
        "cd ~/projects/$project_name && \$SHELL -i -l -c '~/.local/bin/claude --dangerously-skip-permissions; echo \"Claude exited. You are still in the tonka VM. Press Ctrl-D to leave.\"; exec \$SHELL -l'"
}

cmd_cursor() {
    local project_name="${1:-}"
    if [[ -z "$project_name" ]]; then
        die "Usage: tonka cursor <project>"
    fi

    ensure_vm
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    # Check if project exists
    if ! ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" "test -d ~/projects/$project_name" 2>/dev/null; then
        die "Project '$project_name' not found"
    fi

    # Find editor: prefer cursor, fall back to code
    local editor=""
    local cursor_app="/Applications/Cursor.app/Contents/Resources/app/bin/cursor"
    local code_app="/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code"

    if command -v cursor &>/dev/null; then
        editor="cursor"
    elif [[ -x "$cursor_app" ]]; then
        editor="$cursor_app"
    elif command -v code &>/dev/null; then
        editor="code"
        log_warn "Cursor not found, using VS Code"
    elif [[ -x "$code_app" ]]; then
        editor="$code_app"
        log_warn "Cursor not found, using VS Code"
    else
        die "Neither Cursor nor VS Code found. Install one of them."
    fi

    # Use tonka SSH alias if configured, otherwise fall back to user@ip
    local ssh_host="$TART_USER@$ip"
    if grep -q "^Host tonka$" "$HOME/.ssh/config" 2>/dev/null; then
        ssh_host="tonka"
    fi

    log_info "Opening $project_name in $editor via SSH..."
    "$editor" --remote "ssh-remote+$ssh_host" "/Users/$TART_USER/projects/$project_name"
}

cmd_diff_helper() {
    local git_cmd="$1"
    local project_name="${2:-}"
    if [[ -z "$project_name" ]]; then
        die "Usage: tonka $git_cmd <project>"
    fi

    ensure_vm
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    # Find which repo and branch this project belongs to
    local project_info
    project_info=$(ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" \
        "cd ~/projects/$project_name 2>/dev/null && echo \"\$(git rev-parse --path-format=absolute --git-common-dir):\$(git branch --show-current)\"" 2>/dev/null) || die "Project '$project_name' not found"
    local repo_path="${project_info%:*}"
    local branch_name="${project_info#*:}"
    local repo_name
    repo_name=$(basename "$(dirname "$repo_path")")

    # Find the local repo with the same name
    local local_repo
    local_repo=$(git rev-parse --show-toplevel 2>/dev/null) || true
    if [[ "$(basename "$local_repo")" != "$repo_name" ]]; then
        die "Not in the '$repo_name' repository locally"
    fi

    # Sync the repo
    log_info "Syncing from VM repo '$repo_name'..."
    GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=no -i $SSH_KEY" \
        git -C "$local_repo" fetch "$TART_USER@$ip:repos/$repo_name" '+refs/heads/*:refs/remotes/tonka/*'

    local merge_base
    merge_base=$(git -C "$local_repo" merge-base origin/main "tonka/$branch_name")
    git -C "$local_repo" "$git_cmd" "$merge_base..tonka/$branch_name"
}

cmd_diff() {
    cmd_diff_helper diff "$@"
}

cmd_difftool() {
    cmd_diff_helper difftool "$@"
}

cmd_rebuild_base() {
    if vm_exists "$BASE_VM_NAME"; then
        if vm_is_running "$BASE_VM_NAME"; then
            log_info "Stopping base VM..."
            tart stop "$BASE_VM_NAME"
        fi
        log_info "Deleting existing base VM..."
        tart delete "$BASE_VM_NAME"
    fi

    create_base_vm

    # Prompt to rebuild tonka-vm
    if vm_exists "$VM_NAME"; then
        log_warn "tonka-vm exists but was created from the old base."
        log_warn "Rebuilding it will DELETE all repos and projects."
        read -p "Rebuild tonka-vm? [y/N] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            if vm_is_running "$VM_NAME"; then
                log_info "Stopping tonka-vm..."
                tart stop "$VM_NAME"
            fi
            log_info "Deleting tonka-vm..."
            tart delete "$VM_NAME"
            log_info "tonka-vm will be recreated on next use."
        fi
    fi
}

cmd_doctor() {
    local issues=0
    local ssh_opts="-o StrictHostKeyChecking=no -i $SSH_KEY"

    echo "=== Tonka Doctor ==="
    echo ""

    # Host-side file checks
    echo "Host configuration:"
    local host_files="settings.json CLAUDE.md settings.local.json"
    for f in $host_files; do
        local path="$HOME/.claude/$f"
        if [[ -f "$path" ]]; then
            if [[ -L "$path" ]]; then
                echo "  OK      $f (-> $(readlink "$path"))"
            else
                echo "  OK      $f"
            fi
        else
            echo "  MISSING $f"
            ((issues++)) || true
        fi
    done

    # Host-side directory checks
    local host_dirs="skills commands hooks"
    for d in $host_dirs; do
        local path="$HOME/.claude/$d"
        if [[ -d "$path" ]]; then
            local count
            count=$(find -H "$path" -type f -not -name '.DS_Store' | wc -l | tr -d ' ')
            if [[ -L "$path" ]]; then
                echo "  OK      $d/ ($count files, -> $(readlink "$path"))"
            else
                echo "  OK      $d/ ($count files)"
            fi
        else
            echo "  MISSING $d/"
            ((issues++)) || true
        fi
    done

    echo ""
    echo "Credentials:"
    if security find-generic-password -s "Claude Code-credentials" -w &>/dev/null; then
        echo "  OK      Keychain 'Claude Code-credentials'"
    else
        echo "  MISSING Keychain 'Claude Code-credentials'"
        ((issues++)) || true
    fi
    if [[ -f "$HOME/.config/gh/hosts.yml" ]]; then
        echo "  OK      gh credentials"
    else
        echo "  MISSING gh credentials"
        ((issues++)) || true
    fi

    # VM checks
    echo ""
    if ! vm_is_running "$VM_NAME"; then
        echo "VM: not running (start with 'tonka start' for full diagnostics)"
    else
        local ip
        ip=$(get_vm_ip "$VM_NAME")
        echo "VM ($ip):"

        # Compare files
        for f in $host_files; do
            if [[ ! -f "$HOME/.claude/$f" ]]; then
                continue
            fi
            local local_hash remote_hash
            local_hash=$(md5 -q "$HOME/.claude/$f")
            remote_hash=$(ssh $ssh_opts "$TART_USER@$ip" "md5 -q ~/.claude/$f 2>/dev/null" || echo "")
            if [[ -z "$remote_hash" ]]; then
                echo "  MISSING $f"
                ((issues++)) || true
            elif [[ "$local_hash" == "$remote_hash" ]]; then
                echo "  MATCH   $f"
            else
                echo "  STALE   $f"
                ((issues++)) || true
            fi
        done

        # Compare directories
        for d in $host_dirs; do
            if [[ ! -d "$HOME/.claude/$d" ]]; then
                continue
            fi
            local local_hash remote_hash
            local_hash=$(find -H "$HOME/.claude/$d" -type f -not -name '.DS_Store' -exec md5 -q {} \; | sort | md5 -q)
            remote_hash=$(ssh $ssh_opts "$TART_USER@$ip" "find ~/.claude/$d -type f -not -name '.DS_Store' -exec md5 -q {} \; 2>/dev/null | sort | md5 -q" || echo "")
            if [[ -z "$remote_hash" ]]; then
                echo "  MISSING $d/"
                ((issues++)) || true
            elif [[ "$local_hash" == "$remote_hash" ]]; then
                echo "  MATCH   $d/"
            else
                echo "  STALE   $d/"
                ((issues++)) || true
            fi
        done

        # Compare credentials (host Keychain vs VM file)
        local creds
        creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || echo "")
        if [[ -n "$creds" ]]; then
            local local_hash remote_hash
            local_hash=$(echo "$creds" | md5 -q)
            remote_hash=$(ssh $ssh_opts "$TART_USER@$ip" "md5 -q ~/.claude/.credentials.json 2>/dev/null" || echo "")
            if [[ -z "$remote_hash" ]]; then
                echo "  MISSING .credentials.json"
                ((issues++)) || true
            elif [[ "$local_hash" == "$remote_hash" ]]; then
                echo "  MATCH   .credentials.json (Keychain)"
            else
                echo "  STALE   .credentials.json (Keychain)"
                ((issues++)) || true
            fi
        fi

        # Check git credential helper
        if ssh $ssh_opts "$TART_USER@$ip" "git config --global --get credential.helper | grep -q 'gh auth'" 2>/dev/null; then
            echo "  OK      git credential helper"
        else
            echo "  MISSING git credential helper"
            ((issues++)) || true
        fi
    fi

    echo ""
    if [[ $issues -eq 0 ]]; then
        log_info "No issues found."
    else
        log_warn "$issues issue(s) found. Run 'tonka cl <project>' to sync."
    fi
}

cmd_default() {
    ensure_vm
    local ip
    ip=$(get_vm_ip "$VM_NAME")

    # Get list of projects
    local projects
    projects=$(ssh -o StrictHostKeyChecking=no -i "$SSH_KEY" "$TART_USER@$ip" "ls ~/projects 2>/dev/null" || echo "")

    if [[ -z "$projects" ]]; then
        die "No projects found. Create one with: tonka new <project-name> [repo-name]"
    fi

    # Convert to array
    local -a project_list
    while IFS= read -r p; do
        project_list+=("$p")
    done <<< "$projects"

    if [[ ${#project_list[@]} -eq 1 ]]; then
        # Only one project, use it directly
        cmd_cl "${project_list[0]}"
    else
        # Multiple projects, prompt user
        echo "Select a project:"
        local i=1
        for p in "${project_list[@]}"; do
            echo "  $i) $p"
            ((i++))
        done
        read -p "Enter number: " -r choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le ${#project_list[@]} ]]; then
            cmd_cl "${project_list[$((choice-1))]}"
        else
            die "Invalid selection"
        fi
    fi
}

# Main command dispatcher
main() {
    if [[ $# -eq 0 ]]; then
        cmd_default
        exit 0
    fi

    case "$1" in
        new-repo)
            shift
            cmd_new_repo "$@"
            ;;
        new)
            shift
            cmd_new "$@"
            ;;
        pr)
            shift
            cmd_pr "$@"
            ;;
        cp)
            shift
            cmd_cp "$@"
            ;;
        sync)
            cmd_sync
            ;;
        start)
            cmd_start
            ;;
        stop)
            cmd_stop
            ;;
        list)
            cmd_list
            ;;
        sh)
            shift
            cmd_sh "$@"
            ;;
        cl)
            shift
            cmd_cl "$@"
            ;;
        cursor)
            shift
            cmd_cursor "$@"
            ;;
        diff)
            shift
            cmd_diff "$@"
            ;;
        difftool)
            shift
            cmd_difftool "$@"
            ;;
        cleanup)
            cmd_cleanup
            ;;
        rebuild-base)
            cmd_rebuild_base
            ;;
        doctor)
            cmd_doctor
            ;;
        -h|--help|help)
            usage
            ;;
        *)
            die "Unknown command: $1"
            ;;
    esac
}

main "$@"
